{
  "name": "memray-profiler",
  "displayName": "Memray Profiler",
  "description": "VS Code extension to run Memray and display flamegraphs",
  "version": "0.2.2",
  "type": "module",
  "publisher": "JuanMonteiro",
  "repository": "https://github.com/monteirojuan/vscode-memray-extension",
  "engines": {
    "vscode": "^1.80.0"
  },
  "main": "./dist/extension.cjs",
  "scripts": {
    "test:ci": "npm test",
    "build": "webpack --mode production",
    "watch": "webpack --watch --mode development",
    "compile": "tsc -p tsconfig.json",
    "lint": "eslint --ext .ts src",
    "test": "node --import tsx ./node_modules/mocha/bin/mocha --extension ts \"test/**/*.test.ts\" --exit",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^14.0.0",
    "@types/vscode": "^1.60.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vscode/test-electron": "^2.0.0",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^9.39.4",
    "mocha": "^11.7.5",
    "sinon": "^21.0.2",
    "ts-loader": "^9.0.0",
    "ts-node": "^10.0.0",
    "tsx": "^4.20.5",
    "typescript": "^4.5.0",
    "webpack": "^5.0.0",
    "webpack-cli": "^4.0.0"
  },
  "dependencies": {
    "d3": "4.13.0",
    "d3-flame-graph": "4.0.6"
  },
  "overrides": {
    "diff": "^8.0.3",
    "serialize-javascript": "^7.0.0",
    "glob": "^13.0.6"
  },
  "contributes": {
    "commands": [
      {
        "command": "memray.profileFile",
        "title": "Profile with Memray"
      },
      {
        "command": "memray.profileCurrentFile",
        "title": "Profile Current Python File",
        "icon": "$(play)"
      },
      {
        "command": "memray.viewFlamegraph",
        "title": "View Flamegraph"
      },
      {
        "command": "memray.openOutputDirectory",
        "title": "Open Output Directory"
      },
      {
        "command": "memray.deleteResult",
        "title": "Delete Result",
        "icon": "$(trash)"
      },
      {
        "command": "memray.clearResults",
        "title": "Clear All Results",
        "icon": "$(clear-all)"
      },
      {
        "command": "memray.exportHtml",
        "title": "Export as HTML"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "memray",
          "title": "Memray",
          "icon": "media/memray.svg"
        }
      ]
    },
    "views": {
      "memray": [
        {
          "id": "memrayResults",
          "name": "Results",
          "icon": "media/memray.svg"
        }
      ]
    },
    "menus": {
      "commandPalette": [
        {
          "command": "memray.profileCurrentFile",
          "when": "false"
        }
      ],
      "view/item/context": [
        {
          "command": "memray.viewFlamegraph",
          "when": "view == memrayResults && (viewItem == memrayResultHasHtml || viewItem == memrayResultHasNative)",
          "group": "inline"
        },
        {
          "command": "memray.openOutputDirectory",
          "when": "view == memrayResults && viewItem =~ /^memrayResult/",
          "group": "navigation"
        },
        {
          "command": "memray.exportHtml",
          "when": "view == memrayResults && viewItem == memrayResultHasHtml",
          "group": "navigation"
        },
        {
          "command": "memray.deleteResult",
          "when": "view == memrayResults && viewItem =~ /^memrayResult/",
          "group": "inline@99"
        },
        {
          "command": "memray.deleteResult",
          "when": "view == memrayResults && viewItem =~ /^memrayResult/",
          "group": "navigation@99"
        }
      ],
      "view/title": [
        {
          "command": "memray.profileCurrentFile",
          "when": "view == memrayResults && memray.hasWorkspace && memray.activeEditorIsPython",
          "group": "navigation"
        },
        {
          "command": "memray.clearResults",
          "when": "view == memrayResults",
          "group": "navigation@99"
        }
      ]
    },
    "configuration": {
      "title": "Memray",
      "properties": {
        "memray.pythonPath": {
          "type": "string",
          "default": "",
          "description": "Path to Python executable. Leave empty to auto-detect."
        },
        "memray.nativeTracing": {
          "type": "boolean",
          "default": false,
          "description": "Enable native tracing for memray (adds lower-level allocation tracing)."
        },
        "memray.outputDirectory": {
          "type": "string",
          "default": ".memray",
          "description": "Directory (relative to workspace root) where memray artifacts are stored."
        },
        "memray.keepHistoryDays": {
          "type": "number",
          "default": 30,
          "description": "Number of days to keep profiling history before auto-cleanup. Set to 0 to disable."
        },
        "memray.timeoutSeconds": {
          "type": "number",
          "default": 0,
          "description": "Timeout (in seconds) for memray runs. 0 means no timeout."
        }
      }
    }
  },
  "extensionDependencies": [
    "ms-python.python"
  ]
}
